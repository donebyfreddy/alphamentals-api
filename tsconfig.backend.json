{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist-api",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmitOnError": false
  },
  "include": [
    "src/**/*.ts",
    "backend/server/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-api",
    "src/index.ts",
    "src/routes.ts"
  ]
}
