# MT5 Bridge local configuration
# Copy to .env and fill in values

# Shared secret — must match MT5_BRIDGE_API_KEY in the Node API's .env
# Leave blank to disable API key auth (only safe on isolated local networks).
MT5_API_KEY=replace-with-a-long-random-secret

# Host/port — do not change these unless you know what you're doing.
# The bridge MUST stay on 127.0.0.1 (loopback). Never bind to 0.0.0.0.
MT5_API_HOST=127.0.0.1
MT5_API_PORT=8001

# Optional: full path to MetaTrader 5 terminal executable.
# Set this if mt5.initialize() fails to find the terminal automatically.
# MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Optional: pre-configured MT5 credentials (used by /health and /status).
# MT5_LOGIN=12345678
# MT5_PASSWORD=investor-password
# MT5_SERVER=BrokerName-Server
# MT5_ACCOUNT_TYPE=live
# MT5_PASSWORD_TYPE=investor

# Set to true to enable /order and /close endpoints (disabled by default).
MT5_TRADING_ENABLED=false
