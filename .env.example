# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
HOST=0.0.0.0
PORT=3001

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=https://alphamentals-dashboard.pages.dev,https://alphamentals-dashboard.vercel.app,http://localhost:3000

# Optional: override specific origins without touching CORS_ORIGINS
# FRONTEND_ORIGIN=https://your-custom-domain.com
# FRONTEND_ORIGIN_ALT=https://staging.your-custom-domain.com

# ─── MT5 Bridge ───────────────────────────────────────────────────────────────
# URL of the Python MT5 bridge running locally on the VPS.
# MUST be the local bridge (127.0.0.1:8000) — NEVER the public Node API URL.
MT5_BRIDGE_URL=http://127.0.0.1:8000
# Optional explicit API base if your bridge exposes /api/v1 on a different path.
# MT5_TRADEBOT_API_URL=http://127.0.0.1:8000/api/v1
# How long the Node API waits for the bridge before timing out (ms).
MT5_BRIDGE_TIMEOUT_MS=15000
# Shared secret between this API and the MT5 bridge
MT5_BRIDGE_API_KEY=replace-with-a-long-random-secret

# ─── MT5 EA (direct connection) ───────────────────────────────────────────────
# Shared secret between the Node API and the TradeBridgeEA.mq5 Expert Advisor.
# Set the same value in MT5: EA input "BridgeApiKey".
# If left blank, falls back to MT5_BRIDGE_API_KEY — so you can use one key for both.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EA_API_KEY=

MT5_ENABLED=true
MT5_BRIDGE_ENABLED=true
METAAPI_ENABLED=false
# Legacy METAAPI_* variables are ignored unless METAAPI_ENABLED=true.

# ─── API Authentication ────────────────────────────────────────────────────────
# If set, all non-health requests require the header:  x-api-key: <value>
# Leave blank to disable API key auth (default for open internal VPS access).
API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Preferred for direct Postgres access. Must be a valid Supabase PostgreSQL connection string.
DATABASE_URL=
DEFAULT_USER_ID=

# ─── AI providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── Market data providers ────────────────────────────────────────────────────
FRED_API_KEY=
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=
MYFXBOOK_EMAIL=
MYFXBOOK_PASSWORD=
MYFXBOOK_ENABLED=true

# ─── Market intelligence / scraping ───────────────────────────────────────────
SCRAPING_ENABLED=true
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=20000
NEWS_ENABLED=true
FUNDAMENTALS_ENABLED=true

CACHE_TTL_MINUTES=15
NEWS_CACHE_TTL_MINUTES=10
CALENDAR_CACHE_TTL_MINUTES=15
FUNDAMENTALS_CACHE_TTL_MINUTES=30

TIMEZONE=Europe/Madrid

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SYNC_RATE_LIMIT_MS=30000

# ─── Accounts / MT5 connection ────────────────────────────────────────────────
# AES-256-GCM key for encrypting stored MT5 passwords.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production — server will refuse to connect accounts if missing.
ACCOUNT_CREDENTIALS_ENCRYPTION_KEY=change_me_32_byte_secure_key_here

# Set to false to block all live (real-money) trading connections.
# Demo trading-enabled accounts are not affected by this flag.
ACCOUNTS_ALLOW_LIVE_TRADING=false

# Require frontend to send requireConfirmationBeforeTrade=true before any trade.
ACCOUNTS_REQUIRE_TRADE_CONFIRMATION=true

# Default VPS target label if not specified per-account.
ACCOUNTS_DEFAULT_VPS_TARGET=windows-vps-1

# ─── Misc ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
