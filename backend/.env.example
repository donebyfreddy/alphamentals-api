# ── Server ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3001
NODE_ENV=production

# ── CORS / Auth ───────────────────────────────────────────────────────────────
# Internal VPS-to-VPS auth (same value as BRIDGE_API_KEY / MT5_BRIDGE_API_KEY)
VPS_API_KEY=
BRIDGE_API_KEY=
MT5_BRIDGE_API_KEY=
CRON_SECRET=

# Optional second CORS origin (e.g. custom domain)
FRONTEND_ORIGIN=https://alphamentals-dashboard.vercel.app
FRONTEND_ORIGIN_ALT=

# ── Database (Supabase) ───────────────────────────────────────────────────────
SUPABASE_URL=https://lpipbwdknzmnponqqtbw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
DATABASE_URL=
DIRECT_URL=
DEFAULT_USER_ID=

# ── MT5 Bridge (Python service on the same VPS) ───────────────────────────────
# The Python MT5 bridge runs internally on port 8001.
# The Express API server runs on port 3001 and proxies MT5 data.
MT5_BRIDGE_URL=http://127.0.0.1:8001
MT5_BRIDGE_TIMEOUT_MS=15000
MT5_API_HOST=127.0.0.1
MT5_API_PORT=8001
MT5_SERVER_HOST=217.71.203.77

# MT5 account credentials
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PASSWORD_TYPE=investor
MT5_ACCOUNT_TYPE=demo
MT5_AUTO_SYNC_INTERVAL_MS=60000
MT5_TERMINAL_PATH=
MT5_TRADEBOT_API_URL=
MT5_TRADEBOT_API_TIMEOUT=30000

# ── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
KIMI_API_KEY=

# Azure OpenAI alternative (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Economic Calendar ─────────────────────────────────────────────────────────
