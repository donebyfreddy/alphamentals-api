# ── Server ────────────────────────────────────────────────────────────────────
# Port the API server listens on. Nginx proxies 443 → this port.
# Use a port that does NOT conflict with the MT5 bridge (default 3001).
PORT=3000

# Frontend origin allowed for CORS. Set to your Vercel deployment URL.
FRONTEND_ORIGIN=https://your-app.vercel.app
# Optional second origin (e.g. custom domain)
FRONTEND_ORIGIN_ALT=https://app.alphamentals.com

# ── Database (Supabase) ───────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DEFAULT_USER_ID=

# ── MT5 Bridge ────────────────────────────────────────────────────────────────
# URL of the MT5 bridge server (runs on the same VPS, different port).
MT5_BRIDGE_URL=http://127.0.0.1:3001
# Must match BRIDGE_API_KEY set in the MT5 bridge process.
MT5_BRIDGE_API_KEY=
MT5_BRIDGE_TIMEOUT_MS=15000
MT5_BRIDGE_RETRY_ATTEMPTS=3

# MT5 account credentials (for direct MT5 sync, optional if using bridge only)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PASSWORD_TYPE=investor
MT5_ACCOUNT_TYPE=demo
MT5_AUTO_SYNC_INTERVAL_MS=60000
MT5_TERMINAL_PATH=

# ── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=

# Azure OpenAI alternative (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Economic Calendar ─────────────────────────────────────────────────────────
FINNHUB_API_KEY=
TRADING_ECONOMICS_API_KEY=
FOREX_FACTORY_ENABLED=false

# ── Email / Notifications ─────────────────────────────────────────────────────
RESEND_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Telegram Monitoring (optional) ───────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
TELEGRAM_TARGET_CHAT=

# ── TradingView (optional) ────────────────────────────────────────────────────
TRADINGVIEW_SESSIONID=
TRADINGVIEW_SIGNATURE=
TRADINGVIEW_WEBHOOK_SECRET=

# ── Trading Rules ─────────────────────────────────────────────────────────────
TRADING_ENABLED=false
TRADING_ACCOUNT_SIZE=10000
TRADING_RISK_PERCENT=1
TRADING_MIN_RR=2
TRADING_DUPLICATE_WINDOW_MINUTES=180
TRADING_BLOCK_NEWS_MINUTES=30

# ── FRED Macro Data (optional) ────────────────────────────────────────────────
FRED_API_KEY=

# ── AI Analysis Scheduler ─────────────────────────────────────────────────────
AI_ANALYSIS_TIMEZONE=Europe/Madrid
AI_ANALYSIS_REFRESH_INTERVAL_MINUTES=3
AI_ANALYSIS_REFRESH_SYMBOLS=XAUUSD,GBPUSD,EURUSD,DXY,USOIL
CRON_SECRET=
