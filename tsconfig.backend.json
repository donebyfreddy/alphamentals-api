{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "api/dist-api",
    "rootDir": "./api",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmitOnError": false
  },
  "include": [
    "api/src/**/*.ts",
    "api/backend/server/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "api/dist-api",
    "api/src/index.ts",
    "api/src/routes.ts"
  ]
}
